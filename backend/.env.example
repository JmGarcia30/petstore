# Backend Environment Configuration Example

# Database Configuration (PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/petstore
SPRING_DATASOURCE_USERNAME=petstore
SPRING_DATASOURCE_PASSWORD=petstore123
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# CORS Configuration (for local development)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Production: Update CORS_ALLOWED_ORIGINS to include your Render frontend URL:
# CORS_ALLOWED_ORIGINS=https://petstore-frontend.onrender.com

# Server Port
PORT=8080
